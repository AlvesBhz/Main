e=\"background-image: url('https:\/\/valebasemetals.com\/wp-content\/uploads\/2026\/06\/Sust.-Report-VBM_Relatorio-de-Sustentabilidade_Banner_1440x595_20260331-1-scaled.png');\">\r\n                                                    <style>\r\n                                @media screen and (max-width: 560px) {\r\n                                    .banner_6a2c34d77673a {\r\n                                        background-image: url('https:\/\/valebasemetals.com\/wp-content\/uploads\/2026\/06\/Sust.-Report-Banner_Relatorio-de-Sustentabilidade_PT_Mobile-2.png') !important;\r\n                                    }\r\n                                }\r\n                            <\/style>\r\n                        \r\n                        <div class=\"container\">\r\n                            <div class=\"row\">\r\n                                <div class=\"col-md-12 col-lg-7\">\r\n                                    <div class=\"content-text\">\r\n                                        <h2><strong>Sustainability Report<\/strong><\/h2>\n<h3><strong>VBM recently published its 2025 Sustainability Report, marking an important milestone in our transformation and our commitment to transparency. <\/strong><\/h3>\n<h3>Click the button below to read the report!<\/h3>\n\r\n                                                                                    <div class=\"btn__group\">\r\n                                                <a href=\"https:\/\/valebasemetals.com\/sustainability-report\/\" target=\"\" class=\"link_btn\">\r\n                                                    Learn more                                                <\/a>\r\n                                            <\/div>\r\n                                                                            <\/div>\r\n                                <\/div>\r\n                            <\/div>\r\n                        <\/div>\r\n                    <\/div>\r\n                <\/div>\r\n                        <\/div>\r\n<\/section>\n\n\r\n<section class=\"section_texto_imagem_home \" >\r\n    <div class=\"container\">\r\n        \r\n        <div class=\"row\">\r\n            <div class=\"col-md-6 order-2 order-md-2\">\r\n                                    <div class=\"content-img img-center\">\r\n                        <img decoding=\"async\" src=\"https:\/\/valebasemetals.com\/wp-content\/uploads\/2025\/07\/About-us.webp\" alt=\"\"Two Vale employees, a man and a woman in company uniforms and safety glasses, examine a dark rock core sample. A collection of other core samples is laid out on a table in the foreground.\"\" data-aos=\"fade-left\" data-aos-duration=\"2000\"  height=\"\" style=\"width : 90%\" class=\"img-principal\">\r\n                                            <\/div>\r\n                \r\n                \r\n            <\/div>\r\n            <div class=\"col order-1 d-flex align-items-center\">\r\n                <div class=\"content-txt\" style=\"max-width:90%;  \" data-aos=\"fade-right\" data-aos-duration=\"2000\" >\r\n                    <p><strong>About Us<\/strong><\/p>\n<h2>We are Vale Base Metals (VBM)\u00a0 \u2014\u00a0 a global supplier of the critical minerals transforming the future.<\/h2>\n<p>As global demand for critical minerals accelerates, we are transforming our business to deliver a reliable and responsible supply of critical minerals today that will shape the world of tomorrow. Our success will be built on becoming agile, resilient and cost competitive to weather uncertainty, driven by a workforce that is empowered to innovate and deliver results, consistently.<\/p>\n                    <div class=\"buttons-grpup\">\r\n                                                                                            <div class=\"btn__group\">\r\n                                                                                    <a href=\"https:\/\/valebasemetals.com\/about-us\/\" target=\"_self\"                                                class=\"link_btn\"\r\n                                                style=\"border-color: ; color: ; background-color: ;\">\r\n                                                Learn more                                            <\/a>\r\n                                                                            <\/div>\r\n                                                                                                        <\/div>\r\n                                                                            <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n<\/section>\n\n\r\n<section class=\"section_texto_imagem_home \" style=\"background-color: #3cb5e5;\">\r\n    <div class=\"container\">\r\n        \r\n        <div class=\"row\">\r\n            <div class=\"col-md-6 order-2 order-md-0\">\r\n                                    <div class=\"content-img \">\r\n                        <img decoding=\"async\" src=\"https:\/\/valebasemetals.com\/wp-content\/uploads\/2025\/07\/Our-Operations\u200b.webp\" alt=\"An aerial view of a large mining complex nestled in a dense forest, with open-pit excavations visible in the background under a cloudy sky.\"  data-aos=\"fade-right\" data-aos-duration=\"2000\" height=\"\" style=\"width : 90%\" class=\"img-principal\">\r\n                                            <\/div>\r\n                \r\n                \r\n            <\/div>\r\n            <div class=\"col order-1 d-flex align-items-center\">\r\n                <div class=\"content-txt\" style=\"max-width:90%;  \"  data-aos=\"fade-left\" data-aos-duration=\"2000\">\r\n                    <p><strong>Our Operations<\/strong><\/p>\n<h2><span style=\"color: #ffffff;\">Stewards of industry-leading copper and nickel reserves in Canada, Brazil and Indonesia.<\/span><\/h2>\n<p><span style=\"color: #ffffff;\">Our combination of geology and geography positions us to serve customers around the world with a secure and responsible supply of high-quality, next-generation products.<\/span><\/p>\n                    <div class=\"buttons-grpup\">\r\n                                                                                            <div class=\"btn__group\">\r\n                                                                                    <a href=\"https:\/\/valebasemetals.com\/our-operations\/\" target=\"_self\"                                                class=\"link_btn\"\r\n                                                style=\"border-color: #ffffff; color: #ffffff; background-color: ;\">\r\n                                                Learn more                                            <\/a>\r\n                                                                            <\/div>\r\n                                                                                                        <\/div>\r\n                                                                            <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n<\/section>\n\n\r\n<section class=\"section_texto_imagem_home \" >\r\n    <div class=\"container\">\r\n        \r\n        <div class=\"row\">\r\n            <div class=\"col-md-6 order-2 order-md-2\">\r\n                                    <div class=\"content-img img-center\">\r\n                        <img decoding=\"async\" src=\"https:\/\/valebasemetals.com\/wp-content\/uploads\/2025\/07\/Copper-Growth\u200b.webp\" alt=\"A close-up view of coiled, reddish-brown copper wiring, illustrating the company's focus on copper growth projects.\" data-aos=\"fade-left\" data-aos-duration=\"2000\"  height=\"\" style=\"width : 90%\" class=\"img-principal\">\r\n                                            <\/div>\r\n                \r\n                \r\n            <\/div>\r\n            <div class=\"col order-1 d-flex align-items-center\">\r\n                <div class=\"content-txt\" style=\"max-width:%;  \" data-aos=\"fade-right\" data-aos-duration=\"2000\" >\r\n                    <p><strong>Copper Growth<\/strong><\/p>\n<h2>Highly-attractive pipeline of copper growth projects.<\/h2>\n<p>Along with our existing tier-1 mining complex, our Brazilian operations in the Caraj\u00e1s region include a robust pipeline of copper growth projects with above-average grade deposits concentrated in accessible geographies near our existing infrastructure.<\/p>\n                    <div class=\"buttons-grpup\">\r\n                                                                                            <div class=\"btn__group\">\r\n                                                                                    <a href=\"https:\/\/valebasemetals.com\/copper-growth\/\" target=\"_self\"                                                class=\"link_btn\"\r\n                                                style=\"border-color: ; color: ; background-color: ;\">\r\n                                                Learn more                                            <\/a>\r\n                                                                            <\/div>\r\n                                                                                                        <\/div>\r\n                                                                            <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n<\/section>\n\n\r\n<section class=\"section_texto_imagem_home \" >\r\n    <div class=\"container\">\r\n        \r\n        <div class=\"row\">\r\n            <div class=\"col-md-6 order-2 order-md-0\">\r\n                                    <div class=\"content-img \">\r\n                        <img decoding=\"async\" src=\"https:\/\/valebasemetals.com\/wp-content\/uploads\/2025\/07\/Our-products.webp\" alt=\"A metal scoop filled with many small, shiny silver-colored pellets, looking like coins, representing the critical minerals portfolio of nickel, cobalt, and platinum group metals.\"  data-aos=\"fade-right\" data-aos-duration=\"2000\" height=\"\" style=\"width : 90%\" class=\"img-principal\">\r\n                                            <\/div>\r\n                \r\n                \r\n            <\/div>\r\n            <div class=\"col order-1 d-flex align-items-center\">\r\n                <div class=\"content-txt\" style=\"max-width:%;  \"  data-aos=\"fade-left\" data-aos-duration=\"2000\">\r\n                    <p><strong>Our Products<\/strong><\/p>\n<h2>Powering the future with critical minerals.<\/h2>\n<p>Our portfolio includes copper, nickel, cobalt, and other platinum group metals \u2014 essential to powering modern technologies across aerospace, energy, batteries, robotics, and artificial intelligence.<\/p>\n                    <div class=\"buttons-grpup\">\r\n                                                                                            <div class=\"btn__group\">\r\n                                                                                    <a href=\"https:\/\/valebasemetals.com\/our-products\/\" target=\"_self\"                                                class=\"link_btn\"\r\n                                                style=\"border-color: ; color: ; background-color: ;\">\r\n                                                Learn more                                            <\/a>\r\n                                                                            <\/div>\r\n                                                                                                        <\/div>\r\n                                                                            <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n<\/section>\n\n\r\n<section class=\"section_text_background\" style=\"background-image: url('https:\/\/valebasemetals.com\/wp-content\/uploads\/2025\/07\/Sustainability.webp')\">\r\n    <div class=\"container\">\r\n        <div class=\"row\">\r\n            <div class=\"col-md-7\">\r\n                <div class=\"content-txt\">\r\n                    <div class=\"text\" data-aos=\"fade-up\" data-aos-duration=\"2000\">\r\n\r\n                        <p><strong>Sustainability<\/strong><\/p>\n<h2>We know that how we mine is just as important as what we mine.<\/h2>\n<p>We cannot deliver long-term financial value without ensuring we create lasting social and environmental value for our people, communities, and the planet.<\/p>\n                                                    <div class=\"btn__group\">\r\n                                \r\n                                    \r\n                                                                                    <a href=\"https:\/\/valebasemetals.com\/sustainability\/\"\r\n                                                target=\"_self\"                                                class=\"link_btn\"\r\n                                                style=\"border-color: ; color: ;\">\r\n                                                Learn more                                            <\/a>\r\n                                        \r\n                                                                                                <\/div>\r\n                                            <\/div>\r\n\r\n                                            <div class=\"credits_img\">\r\n                            Photographer: Ricardo Teles                        <\/div>\r\n                                    <\/div>\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n\r\n    <div class=\"custom-modal\" id=\"notice-modal\">\r\n        <div class=\"custom-modal__overlay\"><\/div>\r\n        <div class=\"custom-modal__content\">\r\n            <button class=\"custom-modal__close\">&times;<\/button>\r\n            <div class=\"modal-notice\">\r\n                <h3>Notice<\/h3>\r\n\r\n                <p>Vale Base Metals (VBM) will use your email address to send you updates on labour negotiations and potential strike activity at VBM&#8217;s Sudbury, Ontario operations. You may unsubscribe or manage your communication preferences at any time. VBM&#8217;s mailing address is 200 Bay St., Suite 1600, Royal Bank Plaza, South Tower, Toronto, Ontario M5J 2K2 and you may contact us at communications.base.metals@vale.com. For more information about how VBM processes personal information, including retention, sharing and your privacy rights, please see our Privacy Statement.<\/p>\r\n            <\/div>\r\n        <\/div>\r\n    <\/div>\r\n<\/section>\r\n\r\n<script>\r\n    document.addEventListener('DOMContentLoaded', () => {\r\n        const openButtons = document.querySelectorAll('.open-modal');\r\n\r\n        openButtons.forEach(button => {\r\n            button.addEventListener('click', (e) => {\r\n                e.preventDefault();\r\n\r\n                const modalId = button.dataset.modal;\r\n                const modal = document.getElementById(modalId);\r\n\r\n                if (modal) {\r\n                    modal.classList.add('active');\r\n                    document.body.classList.add('modal-open');\r\n                }\r\n            });\r\n        });\r\n\r\n        document.querySelectorAll('.custom-modal').forEach(modal => {\r\n            const overlay = modal.querySelector('.custom-modal__overlay');\r\n            const closeBtn = modal.querySelector('.custom-modal__close');\r\n\r\n            function closeModal() {\r\n                modal.classList.remove('active');\r\n\r\n                if (!document.querySelector('.custom-modal.active')) {\r\n                    document.body.classList.remove('modal-open');\r\n                }\r\n            }\r\n\r\n            overlay.addEventListener('click', closeModal);\r\n            closeBtn.addEventListener('click', closeModal);\r\n        });\r\n\r\n        document.addEventListener('keydown', (e) => {\r\n            if (e.key === 'Escape') {\r\n                document.querySelectorAll('.custom-modal.active').forEach(modal => {\r\n                    modal.classList.remove('active');\r\n                });\r\n                document.body.classList.remove('modal-open');\r\n            }\r\n        });\r\n    });\r\n\r\n    document.addEventListener('wpcf7submit', function(event) {\r\n        if (event.detail.status === 'mail_sent') {\r\n            const form = event.target;\r\n\r\n            setTimeout(() => {\r\n                \/\/ Esconde todos os campos\r\n                form.querySelectorAll(':scope > *:not(.wpcf7-response-output)')\r\n                    .forEach(el => el.style.display = 'none');\r\n\r\n                const response = form.querySelector('.wpcf7-response-output');\r\n\r\n                response.innerHTML = `\r\n                <div class=\"success-message\">\r\n                    <img decoding=\"async\" src=\"https:\/\/valebasemetals.com\/wp-content\/uploads\/2026\/06\/Icone-Check.svg\" alt=\"\">\r\n                    <h3>Subscription confirmed<\/h3>\r\n                    <p><strong>You will now receive notifications whenever this page is updated.<\/strong><\/p>\r\n                    <p>Stay tuned to your inbox (and spam folder) for upcoming communications.<\/p>\r\n                <\/div>\r\n            `;\r\n\r\n            }, 500);\r\n        }\r\n    });\r\n<\/script>\n\n\r\n<section class=\"section-latest-news\" style=\"background-color: #f6f6f6;\">\r\n    <div class=\"container\">\r\n        <div class=\"row\">\r\n            <div class=\"col-md-12\">\r\n                <div class=\"title_section\">\r\n                    <h2 style=\"text-align: center;\">Latest News<\/h2>\n                <\/div>\r\n            <\/div>\r\n\r\n                                <div class=\"col-md-4 mb-4\">\r\n                        <div class=\"content-box\" data-aos=\"fade-up\" data-aos-duration=\"2000\" data-aos-delay=\"200\">\r\n                            <div class=\"content-text\">\r\n\r\n                                <ul class=\"categori-list\">\r\n           